{
  "name": "@relayon/mcp",
  "version": "1.1.0",
  "description": "Relayon.io MCP server — expose the job engine to Claude, Cursor and other MCP-capable AI agents over stdio",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "relayon-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "build": "tsc && chmod +x dist/index.js",
    "check": "npm run clean && npm run typecheck && npm run build",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "pack:dry": "npm pack --dry-run",
    "publish:dry": "npm publish --dry-run --access public",
    "release": "npm run check && npm publish --access public",
    "preflight": "node scripts/preflight.js",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run preflight"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "background-jobs",
    "job-queue",
    "scheduler",
    "cron",
    "relayon",
    "claude",
    "cursor"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Relayon.io",
  "homepage": "https://github.com/gravityhash/relayon-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gravityhash/relayon-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/gravityhash/relayon-mcp/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
